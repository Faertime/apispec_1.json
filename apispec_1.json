{
  "openapi": "3.0.0",
  "info": {
    "title": "Вилка & Ложка - REST API",
    "version": "2.0.0",
    "description": "Сайт ресторана"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:1500"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": [
          "Pages"
        ],
        "summary": "Главная страница",
        "operationId": "get_home",
        "responses": {
          "200": {
            "description": "HTML главной страницы"
          }
        }
      }
    },
    "/about": {
      "get": {
        "tags": [
          "Pages"
        ],
        "summary": "О нас",
        "operationId": "get_about",
        "responses": {
          "200": {
            "description": "HTML страницы о ресторане"
          }
        }
      }
    },
    "/menu": {
      "get": {
        "tags": [
          "Pages"
        ],
        "summary": "Меню ресторана",
        "operationId": "get_menu",
        "responses": {
          "200": {
            "description": "HTML меню с блюдами"
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": [
          "Pages"
        ],
        "summary": "Поиск по меню",
        "operationId": "get_search",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Поисковый запрос"
          }
        ],
        "responses": {
          "200": {
            "description": "Результаты поиска"
          }
        }
      }
    },
    "/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Отправка номера телефона (POST)",
        "operationId": "post_login",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "phone": {
                    "type": "string",
                    "example": "+7 (999) 123-45-67"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "Редирект на подтверждение кода"
          }
        }
      }
    },
    "/login_code": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Подтверждение кода (POST)",
        "operationId": "post_login_code",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string",
                    "example": "1234"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "Редирект в профиль или на регистрацию"
          }
        }
      }
    },
    "/register": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Регистрация нового пользователя (POST)",
        "operationId": "post_register",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Иван Иванов"
                  },
                  "email": {
                    "type": "string",
                    "example": "ivan@mail.ru"
                  },
                  "birthdate": {
                    "type": "string",
                    "example": "01.01.2000"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "Редирект в профиль"
          }
        }
      }
    },
    "/logout": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "Выход из аккаунта (POST)",
        "operationId": "post_logout",
        "responses": {
          "302": {
            "description": "Редирект на главную"
          }
        }
      }
    },
    "/profile": {
      "get": {
        "tags": [
          "Profile"
        ],
        "summary": "Личный кабинет (GET)",
        "operationId": "get_profile",
        "responses": {
          "200": {
            "description": "HTML профиля"
          },
          "302": {
            "description": "Редирект на вход"
          }
        }
      },
      "delete": {
        "tags": [
          "Profile"
        ],
        "summary": "Удаление аккаунта (DELETE)",
        "operationId": "delete_profile",
        "responses": {
          "200": {
            "description": "Аккаунт удален",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Требуется авторизация"
          }
        }
      }
    },
    "/profile/update": {
      "post": {
        "tags": [
          "Profile"
        ],
        "summary": "Обновление через форму (POST)",
        "operationId": "post_profile_update",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Иван Петров"
                  },
                  "phone": {
                    "type": "string",
                    "example": "+7 (999) 987-65-43"
                  },
                  "email": {
                    "type": "string",
                    "example": "petrov@mail.ru"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "Редирект на профиль"
          }
        }
      },
      "put": {
        "tags": [
          "Profile"
        ],
        "summary": "Обновление профиля (PUT)",
        "operationId": "put_profile_update",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "example": "Иван Петров"
                  },
                  "phone": {
                    "type": "string",
                    "example": "+7 (999) 987-65-43"
                  },
                  "email": {
                    "type": "string",
                    "example": "petrov@mail.ru"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Профиль обновлен",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "user": {
                      "type": "object"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные"
          },
          "401": {
            "description": "Требуется авторизация"
          }
        }
      }
    },
    "/cart": {
      "get": {
        "tags": [
          "Cart"
        ],
        "summary": "Корзина (GET)",
        "operationId": "get_cart",
        "responses": {
          "200": {
            "description": "HTML корзины"
          }
        }
      },
      "delete": {
        "tags": [
          "Cart"
        ],
        "summary": "Очистка корзины (DELETE)",
        "operationId": "delete_cart",
        "responses": {
          "200": {
            "description": "Корзина очищена",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/cart/update": {
      "post": {
        "tags": [
          "Cart"
        ],
        "summary": "Изменение количества (POST)",
        "operationId": "post_cart_update",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "item_id": {
                    "type": "string"
                  },
                  "action": {
                    "type": "string",
                    "example": "inc"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "302": {
            "description": "Редирект на корзину"
          }
        }
      },
      "put": {
        "tags": [
          "Cart"
        ],
        "summary": "Полное обновление корзины (PUT)",
        "operationId": "put_cart_update",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "items": {
                    "type": "object",
                    "example": {
                      "5": 2,
                      "7": 1
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Корзина обновлена",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "cart": {
                      "type": "object"
                    },
                    "total": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Некорректные данные"
          }
        }
      }
    },
    "/add_to_cart/{item_id}": {
      "post": {
        "tags": [
          "Cart"
        ],
        "summary": "Добавление блюда в корзину (POST)",
        "operationId": "post_add_to_cart",
        "parameters": [
          {
            "name": "item_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Редирект на меню"
          }
        }
      }
    },
    "/checkout": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Оформление заказа (POST)",
        "operationId": "post_checkout",
        "responses": {
          "200": {
            "description": "HTML подтверждения заказа"
          },
          "302": {
            "description": "Редирект на вход (не авторизован)"
          }
        }
      }
    },
    "/booking": {
      "get": {
        "tags": [
          "Booking"
        ],
        "summary": "Форма бронирования (GET)",
        "operationId": "get_booking",
        "responses": {
          "200": {
            "description": "HTML формы бронирования"
          },
          "302": {
            "description": "Редирект на вход"
          }
        }
      },
      "post": {
        "tags": [
          "Booking"
        ],
        "summary": "Создание брони (POST)",
        "operationId": "post_booking",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "date": {
                    "type": "string",
                    "example": "20.05.2026"
                  },
                  "time": {
                    "type": "string",
                    "example": "19:00"
                  },
                  "guests": {
                    "type": "string",
                    "example": "2"
                  },
                  "comment": {
                    "type": "string",
                    "example": "У окна"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "HTML подтверждения брони"
          }
        }
      }
    },
    "/booking/cancel/{booking_id}": {
      "post": {
        "tags": [
          "Booking"
        ],
        "summary": "Отмена брони через форму (POST)",
        "operationId": "post_booking_cancel",
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Редирект в профиль"
          }
        }
      },
      "delete": {
        "tags": [
          "Booking"
        ],
        "summary": "Удаление брони (DELETE)",
        "operationId": "delete_booking_cancel",
        "parameters": [
          {
            "name": "booking_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Бронь удалена",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Требуется авторизация"
          },
          "404": {
            "description": "Бронь не найдена"
          }
        }
      }
    }
  }
}